#cylinder
def cylinderVCT(radius , height):
 volume = pi * pow(radius , 2) * height
 csa = 2* pi * radius * height
 tsa = 2* pi * radius * height + 2 * pi * pow(radius , 2)

 print(f"volume of cylinder is : {volume}")
 print(f"csa of cylinder is : {csa}")
 print(f"tsa of cylinder is : {tsa}")

radius = float(input("enter the radius : "))
height = float (input("enter the height : "))

cylinderVCT(radius , height)

#cone
def coneVCT (radius , slant , height):
    volume = (1/3)*pi*pow(radius , 2 )*height
    csa = pi * radius * height
    tsa = pi * radius  * (radius + slant )

    print (f"volume of cone is : {volume}")
    print (f"csa of cone is : {csa}")
    print (f"tsa of cone is : {tsa}")

radius = float(input("enter the radius : "))
slant = float(input("enter the slant  : "))
height = float(input("enter the height : "))
    

coneVCT (radius , slant , height)
